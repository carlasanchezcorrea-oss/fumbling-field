---
import "../styles/global.css";

import Navbar from "../components/ui/Navbar.vue";
import FooterSection from "../features/shared/components/FooterSection.astro";
import FooterLinks from "../features/shared/components/FooterLinks.astro";

const GA_ID = import.meta.env.PUBLIC_GA_ID;
const META_PIXEL_ID = import.meta.env.PUBLIC_META_PIXEL_ID;

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>You're a VIP | Protein Dispenser DP-M2</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .ty-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 80px 24px;
        text-align: center;
      }

      .ty-icon-wrap {
        margin-bottom: 32px;
        opacity: 0;
        transform: translateY(20px);
        animation: ty-fadeUp 0.6s ease forwards;
      }

      .ty-icon-wrap svg {
        width: 100px;
        height: 100px;
      }

      /* SVG icon colors — prefixed ty-svg- to avoid conflicts with onepage */
      .ty-svg-1 {
        fill: #549ffe;
      }
      .ty-svg-2 {
        fill: #338dee;
      }
      .ty-svg-3 {
        fill: #fdc957;
      }
      .ty-svg-4 {
        fill: #feccbe;
      }
      .ty-svg-5 {
        fill: #febdab;
      }
      .ty-svg-6 {
        fill: #f3b537;
      }

      .ty-headline {
        margin-bottom: 12px;
        opacity: 0;
        transform: translateY(20px);
        animation: ty-fadeUp 0.6s ease 0.15s forwards;
      }

      .ty-subheadline {
        font-size: 14px;
        margin-bottom: 48px;
        opacity: 0;
        transform: translateY(20px);
        animation: ty-fadeUp 0.6s ease 0.3s forwards;
      }

      .ty-benefits {
        font-size: 14px;
        display: flex;
        flex-direction: column;
        gap: 16px;
        width: 100%;
        max-width: 540px;
        margin-bottom: 48px;
        opacity: 0;
        transform: translateY(20px);
        animation: ty-fadeUp 0.6s ease 0.45s forwards;
      }

      .ty-card {
        border: 1px solid rgba(128, 128, 128, 0.25);
        border-radius: 12px;
        padding: 24px 28px;
        text-align: left;
        display: flex;
        gap: 18px;
        align-items: flex-start;
      }

      .ty-card-icon {
        font-size: 1.5rem;
        flex-shrink: 0;
        margin-top: 2px;
      }

      .ty-card-title {
        font-weight: 700;
        margin-bottom: 6px;
      }

      .ty-closing {
        font-size: 14px;
        opacity: 0;
        transform: translateY(20px);
        animation: ty-fadeUp 0.6s ease 0.6s forwards;
      }

      @keyframes ty-fadeUp {
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (max-width: 480px) {
        .ty-main {
          padding: 90px 24px 60px;
        }
        .ty-card {
          padding: 20px;
        }
      }
    </style>
  </head>
