---
import Layout from "../layouts/MainLayout.astro";
---

<Layout>
  <main class="container-global">
    <h1 class="fade-up">Refund Policy</h1>

    <h2 class="fade-up">Section 1 – VIP Reservation Fee</h2>
    <p class="fade-up">
      The $1.00 USD VIP Priority Reservation fee is <strong
        >non-refundable</strong
      >. This fee is charged for immediate access to digital benefits, including
      priority status, exclusive project updates, and guaranteed access to the
      lowest launch pricing.
    </p>

    <h2 class="fade-up">Section 2 – Newsletter Subscription</h2>
    <p class="fade-up">
      Subscription to the newsletter is free. You may unsubscribe at any time by
      clicking the "unsubscribe" link at the bottom of our emails. No refunds
      apply as no payment is required for the newsletter.
    </p>

    <h2 class="fade-up">Section 3 – Kickstarter Pledges</h2>
    <p class="fade-up">
      Refund policies for the actual product purchase during the Kickstarter
      campaign will be specified on the official Kickstarter project page. Those
      pledges are separate from the $1.00 USD reservation fee.
    </p>

    <h2 class="fade-up">Section 4 – Legal Notice</h2>
    <p class="fade-up">
      Please note that the "cooling-off" system under Japanese law does not
      apply to online reservation fees for digital benefits. By completing the
      $1.00 USD transaction, you acknowledge and agree to this policy.
    </p>
  </main>
</Layout>

<style>
  main {
    padding-top: 100px;
    padding-bottom: 70px;
    font-family: "RalewayRegular";
  }
  h1 {
    font-family: "RalewayExtraBold";

    font-size: clamp(26px, 6vw, 36px);
    margin-bottom: 24px;
    line-height: 1.2;
  }

  h2 {
    font-family: "RalewayExtraBold";

    font-size: clamp(18px, 4.5vw, 22px);
    margin-top: 28px;
    margin-bottom: 10px;
    line-height: 1.3;
  }

  p {
    font-size: clamp(14px, 3.8vw, 16px);
    line-height: 1.7;
    margin-bottom: 16px;
    color: #555;
  }
  /* Estado inicial */
  .fade-up {
    opacity: 0;
    transform: translateY(24px) scale(0.98);
    filter: blur(6px);

    transition:
      transform 0.6s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.6s ease,
      filter 0.6s ease;
  }

  .fade-up.show {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
  }

  @media (max-width: 640px) {
    h2 {
      margin-top: 32px;
      padding-top: 16px;
      border-top: 1px solid #eee;
    }

    p {
      padding-left: 2px;
    }
  }
</style>
<script>
  const elements = document.querySelectorAll(".fade-up");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("show");
        }
      });
    },
    {
      threshold: 0.15,
    },
  );

  elements.forEach((el) => observer.observe(el));
</script>
