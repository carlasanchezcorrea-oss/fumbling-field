---
import Layout from "../layouts/MainLayout.astro";
---

<Layout>
  <main class="container-global">
    <h1 class="fade-up">Terms &amp; Conditions</h1>

    <p class="fade-up">
      <strong>Overview:</strong> These Terms &amp; Conditions ("Terms") set forth
      the conditions for participating in the DP-M2 Pre-launch campaign operated by
      Miaomada Co., Ltd. By subscribing to our newsletter or completing a VIP reservation,
      you agree to these Terms and our Privacy Policy.
    </p>

    <h2 class="fade-up">Section 1 – Participation Levels</h2>
    <ul class="fade-up">
      <li class="fade-up">
        <strong>Newsletter Subscriber:</strong> By providing your email, you agree
        to receive free updates and marketing communications regarding the DP-M2 project.
      </li>
      <li class="fade-up">
        <strong>VIP Priority Member:</strong> By paying a $1.00 USD reservation fee,
        you obtain "VIP Status," which grants you access to the lowest guaranteed
        price (Super Early Bird) and priority shipping during the official Kickstarter
        launch.
      </li>
    </ul>

    <h2 class="fade-up">Section 2 – VIP Reservation Conditions</h2>
    <p class="fade-up">
      The $1.00 USD fee is a Priority Reservation only. It is <strong
        >NOT</strong
      > a purchase of a physical product. To receive the product, you must complete
      a separate purchase ("pledge") on the Kickstarter platform during the official
      campaign.
    </p>

    <h2 class="fade-up">Section 3 – Kickstarter Platform</h2>
    <p class="fade-up">
      The official launch will take place on Kickstarter. All final orders are
      subject to Kickstarter's own Terms of Use and Privacy Policy. Miaomada
      Co., Ltd. is responsible for product fulfillment following the successful
      completion of the Kickstarter campaign.
    </p>

    <h2 class="fade-up">Section 4 – Governing Law</h2>
    <p class="fade-up">
      These Terms shall be governed by Japanese law. Any disputes arising in
      connection with this campaign shall be subject to the exclusive
      jurisdiction of the Tokyo District Court.
    </p>
  </main>
</Layout>

<style>
  main {
    padding-top: 100px;
    padding-bottom: 70px;
    font-family: "RalewayRegular";
  }
  h1 {
    font-family: "RalewayExtraBold";

    font-size: clamp(26px, 6vw, 36px);
    margin-bottom: 24px;
    line-height: 1.2;
  }

  h2 {
    font-family: "RalewayExtraBold";

    font-size: clamp(18px, 4.5vw, 22px);
    margin-top: 28px;
    margin-bottom: 10px;
    line-height: 1.3;
  }

  p {
    font-size: clamp(14px, 3.8vw, 16px);
    line-height: 1.7;
    margin-bottom: 16px;
    color: #555;
  }

  /* Estado inicial */
  .fade-up {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.6s ease;
  }

  /* Cuando aparece */
  .fade-up.show {
    opacity: 1;
    transform: translateY(0);
  }

    @media (max-width: 640px) {
    h2 {
      margin-top: 32px;
      padding-top: 16px;
      border-top: 1px solid #eee;
    }

    p {
      padding-left: 2px;
    }
  }
</style>
<script>
  const elements = document.querySelectorAll(".fade-up");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("show");
        }
      });
    },
    {
      threshold: 0.15,
    },
  );

  elements.forEach((el) => observer.observe(el));
</script>
