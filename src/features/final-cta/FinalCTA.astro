---
import "./final-cta.css";
---

<section class="cta container-global" id="cta">
  <div class="cta-container">
    <!-- TEXTO -->
    <div class="cta-text reveal">
      <h3 class="text-h3">Don't miss the drop.</h3>

      <p class="text-description">
        Our best offers vanish in the first 48 hours. Sign up to get notified
        the second we go live and secure your spot at the front of the line.
      </p>
    </div>

    <!-- FORM -->
    <div>
      <div id="error-message-container"></div>
      <form
        class="cta-form reveal delay"
        data-form="banner_01_form"
        id="lead-form_01"
      >
        <input
          type="email"
          name="email"
          placeholder="Enter your email"
          class="text-description"
          required
        />
        <button class="text-main" id="notify-btn" type="submit"
          >Notify me</button
        >
      </form>
    </div>
  </div>
</section>

<script>
  const elements = document.querySelectorAll(".reveal");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("show");
        }
      });
    },
    { threshold: 0.2 },
  );

  elements.forEach((el) => observer.observe(el));

  // FUNCTION SUBMIT LEADS
</script>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const form_01 = document.getElementById("lead-form_01");
    if (!form_01) return;

    const emailInput = form_01.querySelector("input[name='email']");
    const button = form_01.querySelector("button[type='submit']");

    // 🔴 contenedor de error dinámico
    let errorEl = form_01.querySelector(".error-message");
    let errorElcontainer = document.querySelector("#error-message-container");

    if (!errorEl) {
      errorEl = document.createElement("p");
      errorEl.className = "error-message";
      errorEl.style.color = "#ff4d4f";
      errorEl.style.fontSize = "14px";
      errorEl.style.marginTop = "6px";
      errorElcontainer.appendChild(errorEl);
    }

    form_01.addEventListener("submit", async (e) => {
      e.preventDefault();

      const email = emailInput?.value;
      const formName = form_01.dataset.form || "unknown_form";

      if (!email) return;

      // 🧼 limpiar mensaje previo
      errorEl.textContent = "";

      // 🔄 loading state
      button.disabled = true;
      button.textContent = "Sending...";

      try {
        const response = await fetch(
          "https://dpm2.miaomada.co.jp/api/leads-save.php",
          {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              email,
              source: formName,
            }),
          },
        );

        const data = await response.json(); // 👈 CLAVE

        if (!response.ok) {
          throw new Error("Error en la respuesta");
        }

        // 🔴 DUPLICADO
        if (data.type === "duplicate") {
          console.log("⚠️ Email duplicado:", data);

          errorEl.textContent = data.message; // 👈 mostrar mensaje
          return; // ⛔ cortar flujo
        }

        // 🟢 SOLO SI ES NUEVO
        if (data.success === true) {
          sessionStorage.setItem("registrated", true);
          sessionStorage.setItem("email", emailInput?.value);
          sessionStorage.setItem("formName", formName);

          // emailInput?.value = "";
          // errorEl.value = "";
          // 🧹 reset + redirect
          form_01.reset();

          window.location.href = "/thank-you-newsletter";
        }
      } catch (error) {
        console.error("🔥 Error:", error);
        errorEl.textContent = "Ocurrió un error. Inténtalo nuevamente.";
      } finally {
        // 🔁 restaurar botón
        button.disabled = false;
        button.textContent = "Notify me";
      }
    });
  });
</script>

<style scoped>
  /* ========================= */
  /* 📱 MOBILE */
  /* ========================= */

  @media (max-width: 768px) {
    .cta {
    }
    .cta-container {
      flex-direction: column;
      align-items: flex-start;
    }
    .cta-container .cta-text,
    .cta-container .cta-form {
      width: 100%;
    }
    .cta-text h3 {
      font-size: 36px;
    }
    .cta-text p {
      font-size: 16px;
      margin-bottom: 15px;
    }

    /* FORM */
    .cta-form {
      margin-left: 0;
      flex-direction: column;
      width: 100%;
    }

    .cta-form input,
    .cta-form button {
      width: stretch;
    }
    .cta-form .text-main {
      font-size: 16px !important;
    }
  }
</style>
