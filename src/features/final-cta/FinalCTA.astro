  }

  /* FORM */
  .cta-form {
    width: 100%;
    display: flex;
    gap: 10px;
    margin-left: 50px;
  }

  .cta-form input {
    padding: 14px 16px;
    border-radius: 10px;
    border: none;
    flex: 1;
  }

  .cta-form button {
    min-width: 170px;
    padding: 14px 20px;
    border-radius: 10px;
    border: none;
    background: #1e88e5;
    color: white;
    cursor: pointer;
  }

    .cta-form .text-main {
      font-size: 16px !important;
    }

  /* ========================= */
  /* ✨ ANIMACIÓN */
  /* ========================= */

  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.4s ease-out;
  }

  .reveal.show {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal p {
    text-align: justify;
  }

  /* Delay para efecto más PRO */
  .delay {
    transition-delay: 0.15s;
  }

  /* ========================= */
  /* 📱 MOBILE */
  /* ========================= */

  @media (max-width: 768px) {
    .cta {
    }

