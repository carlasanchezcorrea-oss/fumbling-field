---
import "./final-cta.css";
---

<section class="cta container-global" id="cta">
  <div class="cta-container">
    <!-- TEXTO -->
    <div class="cta-text reveal">
      <h3 class="text-h3">Ready to upgrade your routine?</h3>

      <p class="text-description">
        Be the first to know when DP-M2 goes live and secure your spot in line
        for Super Early Bird access.
      </p>
    </div>

    <!-- FORM -->
    <form
      class="cta-form reveal delay"
      data-form="banner_02_form"
      id="lead-form_02"
    >
      <input
        type="email"
        name="email"
        placeholder="Enter your email"
        class="text-description"
        required
      />
      <button class="text-main" type="submit">Notify me</button>
    </form>
  </div>
</section>

<script>
  const elements = document.querySelectorAll(".reveal");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("show");
        }
      });
    },
    { threshold: 0.2 },
  );

  elements.forEach((el) => observer.observe(el));
</script>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const form_02 = document.getElementById("lead-form_02");

    if (!form_02) return;

    form_02.addEventListener("submit", async (e) => {
      e.preventDefault();

      const emailInput = form_02.querySelector("input[name='email']");
      const email = emailInput?.value;
      const formName = form_02.dataset.form || "unknown_form";
      const button = form_02.querySelector("button");

      console.log("🟢 Submit funcionando");
      console.log({ email: email, formName: formName, button: button });

      // 🔄 Estado loading
      button.disabled = true;
      button.textContent = "Sending...";

      try {
        const response = await fetch(
          "https://dpm2.miaomada.co.jp/api/leads-save.php",
          {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              email,
              source: formName,
            }),
          },
        );

        if (!response.ok) {
          throw new Error("Error en la respuesta");
        }

        console.log("✅ Lead enviado");

        // 📊 GA4 event
        if (typeof gtag === "function") {
          gtag("event", "lead", {
            method: "newsletter",
            form_name: formName,
            value: "",
            currency: "",
          });
          // Esperar 300ms para asegurar que GA4 registre el evento
          await new Promise((resolve) => setTimeout(resolve, 300));
        }
        // ✅ Verificar que Meta Pixel esté cargado
        if (typeof fbq === "function") {
          fbq("track", "Lead", {
            method: "newsletter",
            form_name: formName,
            value: "",
            currency: "",
            content_type: "product",
            // content_ids: ['prod_123'], // 👈 Opcional: IDs de productos
            debug_mode: true, // 👈 Solo para desarrollo (no es parámetro oficial de Meta)
          });
          console.log("📡 Evento 'Lead' enviado a Meta Pixel");
        } else {
          console.warn(
            "⚠️ fbq no está definido - ¿Está instalado el Meta Pixel?",
          );
        }
        // 🧹 Reset
        form_02.reset();
        window.location.href = "/thank-you-newsletter";
      } catch (error) {
        console.error("🔥 Error:", error);
      } finally {
        // 🔁 Restaurar botón
        button.disabled = false;
        button.textContent = "Notify me";
      }
    });
  });
</script>

<style scoped>
  .cta {
    background-image:
      linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)),
      url("/assets/cta/bg-cta-2.png");

    background-size: 115%;
    background-position: right center;
    background-repeat: no-repeat;
  }
  /* ========================= */
  /* 📱 MOBILE */
  /* ========================= */

  @media (max-width: 768px) {
    .cta {
      background-image:
        linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)),
        url("/assets/cta/bg-cta-2.png");

      background-size: cover;
      background-position: center center;
      background-repeat: no-repeat;
    }
    .cta-container {
      flex-direction: column;
      align-items: flex-start;
    }
    .cta-container .cta-text,
    .cta-container .cta-form {
      width: 100%;
    }
    .cta-text h3 {
      font-size: 36px;
    }
    .cta-text p {
      font-size: 16px;
      margin-bottom: 15px;
    }

    /* FORM */
    .cta-form {
      margin-left: 0;
      flex-direction: column;
      width: 100%;
    }

    .cta-form input,
    .cta-form button {
      width: stretch;
    }
    .cta-form .text-main {
      font-size: 16px !important;
    }
  }
</style>
