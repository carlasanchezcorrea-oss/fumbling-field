---
import "./product-intro.css";
---

<section class="feature container-global" id="problem">
  <div class="container">
    <!-- BLOQUE 1 -->
    <div class="row">
      <div class="image">
        <div class="image-1"></div>
        <!-- <img src="/assets/productIntro/product-1.jpg" alt="" /> -->
      </div>

      <div class="text">
        <h3 class="text-h3">Still using a scoop?</h3>
        <p class="text-h3 sub">It's time for an upgrade</p>
        <p class="text-description">
          The traditional way is messy, slow, and unnecessarily frustrating.
        </p>
      </div>
    </div>

    <!-- BLOQUE 2 -->
    <div class="row reverse">
      <div class="image">
        <div class="image-2"></div>
        <!-- <img src="/assets/productIntro/product-2.jpg" alt="" /> -->
      </div>

      <div class="text">
        <h3 class="text-h3">Why scoop when you can slide?</h3>
        <p class="text-h3 sub">Meet the DP-M2</p>
        <p class="text-description">
          The precision your routine deserves.
          <br />
          One slide. Perfect portion. In seconds. No mess. No friction.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- SCRIPT -->
<script>
  const rows = document.querySelectorAll(".row");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("show");
        }
      });
    },
    { threshold: 0.2 },
  );

  rows.forEach((row) => observer.observe(row));
</script>

<style scoped>
  /* ========================= */
  /* 📱 MOBILE (390px) */
  /* ========================= */

  @media (max-width: 768px) {
    .feature {
      padding-top: 90px;
      padding-bottom: 90px;
    }

    .row {
      flex-direction: column;
      gap: 20px;
      margin-bottom: 60px;
    }
    .row .image,
    .row .text {
      width: 100%;
    }

    .reverse {
      flex-direction: column;
    }

    .feature .text h3 {
      font-size: 3.4rem;
  margin-bottom: 0rem;
    }
    .feature .text-h3.sub {
      font-size: 2rem;
      margin-bottom: 0.5rem;
  margin-bottom: 0rem;
    }
    .feature .text-description {
      font-size: 1.6rem;
      line-height: 1.5;
    }
    /* IMAGE */
    .image div {
      width: 100%;
      max-width: 500px;
      max-width: fit-content;
    }
    .image {
      width: 100%;
    }
    .image div {
      width: 100%;
      min-width: 100%;
      height: 300px;
      background-position: top;
    }
  }
</style>
