---
import "./pricing.css";
---

<section class="promo-section container-global" id="vip">
  <div class="background-overlay"></div>

  <div class="promo-section_container">
    <!-- Texto Principal (Visible en ambos, posición cambia) -->
    <div class="header-content">
      <h3 class="main-title">
        <span class="text-p">Skip the Line.</span>
        <br />
        <strong class="text-main">Get the Best.</strong>
      </h3>
      <p class="text-p subtitle">
        <strong>Reserve priority access to DP-M2 for just $1</strong> and lock in
        the lowest price of the entire campaign before Super Early Bird spots sell
        out.
      </p>
    </div>

    <!-- Tarjeta Blanca -->
    <div class="card">
      <div class="price-tag">
        <p class="text-p">$<span>1</span></p>
      </div>

      <ul class="features-list">
        <li class="feature-item">
          <div class="icon-check">
            <svg
              width="16"
              height="16"
              viewBox="0 0 16 16"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M13.6666 4L5.99992 11.6667L2.33325 8"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>
          <div class="feature-text">
            <h3 class="text-h3">Guaranteed Super Early Bird pricing.</h3>
            <p class="text-p">Secure our best launch offer (up to 40% off).</p>
          </div>
        </li>

        <li class="feature-item">
          <div class="icon-check">
            <svg
              width="16"
              height="16"
              viewBox="0 0 16 16"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M13.6666 4L5.99992 11.6667L2.33325 8"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>
          <div class="feature-text">
            <h3 class="text-h3">Batch #1 Priority Shipping</h3>
            <p class="text-p">
              Fast-track your order. Be the first to receive DP-M2.
            </p>
          </div>
        </li>

        <li class="feature-item">
          <div class="icon-check">
            <svg
              width="16"
              height="16"
              viewBox="0 0 16 16"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M13.6666 4L5.99992 11.6667L2.33325 8"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>
          <div class="feature-text">
            <h3 class="text-h3">Insider Updates</h3>
            <p class="text-p">
              Exclusive behind-the-scenes content and early announcements.
            </p>
          </div>
        </li>
      </ul>

      <hr />
      <!-- COUNTDOWN REGISTER -->
      <div class="countdow-register text-h3">
        <div>
          <p>Only</p>
        </div>
        <p class="number">75</p>

        <div>
          <p>spots left!</p>
        </div>
      </div>

      <!-- BUTTON -->
      <a
        href="https://tu-enlace-aqui.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-main cta-button"
      >
        Reserve My Spot Now
      </a>

      <p class="disclaimer text-p">*Priority spots will be limited.</p>
    </div>
  </div>
</section>

<style scoped>
  /* ========================= */
  /* 📱 MOBILE */
  /* ========================= */
  /* Ajustes específicos para Mobile 390px */
  @media (max-width: 480px) {
    .promo-section .header-content .subtitle {
      max-width: 100%;
    }
    .promo-section .header-content .text-p.subtitle {
      font-size: 1.6rem;
    }
    .promo-section .header-content, .header-conten .card,
    .header-conten .card {
      width: 100%;
      min-width: 100%;
    }
    .promo-section_container {
      flex-direction: column;
    }
    .main-title {
      font-size: 2.2rem;
    }

    .promo-section_container .card {
      padding: 2rem 1.5rem;
      border-radius: 20px;
    }

    .price-tag .text-p {
      font-size: 96px;
    }
    .price-tag .text-p span {
      font-size: 128px;
    }
  }
</style>
