---
import SectionVip from "./PricingOffer.astro";
---

<div id="promo-vip-modal" class="modal-overlay-pricing-vip">
  <div class="modal-content">
    <button class="modal-close" id="close-vip-modal">✕</button>

    <!-- TU COMPONENTE -->
    <SectionVip client:load />
  </div>
</div>

<style>
  /* ========================= */
  /* MODAL BASE */
  /* ========================= */
  .modal-overlay-pricing-vip {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.75);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;

    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.4s ease,
      visibility 0.4s ease;
  }

  /* Estado activo */
  .modal-overlay-pricing-vip.active {
    opacity: 1;
    visibility: visible;
  }

  /* CONTENIDO */
  .modal-overlay-pricing-vip .modal-content {
    position: relative;
    width: 90%;
    max-width: 900px;
    max-height: 90vh;

    overflow-y: auto;
    border-radius: 20px;

    /* 👇 estado inicial */
    transform: translateY(40px) scale(0.95);
    opacity: 0;

    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  /* 👇 cuando abre */
  .modal-overlay-pricing-vip.active .modal-content {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  /* BOTÓN CERRAR */
  .modal-overlay-pricing-vip .modal-close {
    position: absolute;
    top: 12px;
    right: 12px;
    background: #000;
    color: #fff;
    border: none;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    cursor: pointer;
    z-index: 10;
  }

  /* ========================= */
  /* AJUSTES PARA TU SECTION */
  /* ========================= */

  /* Mobile fix */
  @media (max-width: 768px) {
    .modal-overlay-pricing-vip .modal-content {
      width: 95%;
      max-height: 85vh;
    }
  }
  @media (max-width: 480px) {
    .modal-overlay-pricing-vip .modal-close {
      background: #fff;
      color: #000;
      font-weight: bolder;
      stroke-width: 2px;
    }
  }

  /* ========================= */
  /* 🖥️ DESKTOP(1440+) */
  /* ========================= */
  @media (min-width: 1440px) {
    .modal-overlay-pricing-vip .modal-content {
      max-width: 1224px;
      max-height: 85vh;
    }
  }
</style>

<script>
  // ==========================
  // 🔒 CONFIG GLOBAL
  // ==========================
  let wasPopupShown = false;

  // ==========================
  // 🚀 FUNCIÓN CENTRAL
  // ==========================
  function showVipPopup() {
    if (wasPopupShown) return; // evita duplicados

    wasPopupShown = true;

    const modal = document.getElementById("promo-vip-modal");

    if (!modal) return;

    // mostrar modal
    modal.classList.add("active");
    document.body.style.overflow = "hidden";

    // guardar persistencia
    localStorage.setItem("vip_offer_closed", "true");

    // limpiar listeners (opcional pero PRO)
    removeEventListeners();
  }

  // ==========================
  // ❌ CERRAR MODAL
  // ==========================
  function closeVipPopup() {
    const modal = document.getElementById("promo-vip-modal");

    if (!modal) return;

    modal.classList.remove("active");
    document.body.style.overflow = "";

    localStorage.setItem("vip_offer_closed", "true");
  }

  // ==========================
  // 📉 SCROLL 25%
  // ==========================
  function handleScroll() {
    const scrollTop = window.scrollY;
    const docHeight =
      document.documentElement.scrollHeight - window.innerHeight;

    const scrollPercent = (scrollTop / docHeight) * 100;

    if (scrollPercent >= 25) {
      showVipPopup();
    }
  }

  // ==========================
  // 🚪 EXIT INTENT (DESKTOP)
  // ==========================
  function handleExitIntent(e) {
    if (e.clientY <= 0) {
      showVipPopup();
    }
  }

  // ==========================
  // 🧹 LIMPIAR EVENTOS (PRO)
  // ==========================
  function removeEventListeners() {
    window.removeEventListener("scroll", handleScroll);
    document.removeEventListener("mouseleave", handleExitIntent);
  }
  // ==========================
  // 🟢 INIT
  // ==========================
  document.addEventListener("DOMContentLoaded", () => {
    // 🔒 SI YA INTERACTUÓ → NO HACER NADA
    if (localStorage.getItem("vip_offer_closed")) return;

    const closeBtn = document.getElementById("close-vip-modal");
    const modal = document.getElementById("promo-vip-modal");

    // ==========================
    // ⏱️ TIMEOUT 15s
    // ==========================
    const timeout = setTimeout(() => {
      showVipPopup();
    }, 15000);

    // ==========================
    // 🎯 EVENTOS
    // ==========================
    window.addEventListener("scroll", handleScroll);
    document.addEventListener("mouseleave", handleExitIntent);

    // ==========================
    // ❌ CERRAR
    // ==========================
    if (closeBtn) {
      closeBtn.addEventListener("click", () => {
        closeVipPopup();
        clearTimeout(timeout);
      });
    }

    // click fuera del modal
    if (modal) {
      modal.addEventListener("click", (e) => {
        if (e.target === modal) {
          closeVipPopup();
          clearTimeout(timeout);
        }
      });
    }
  });
</script>
