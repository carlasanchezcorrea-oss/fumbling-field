---
import "./pricing.css";
---

<section class="promo-section" id="vip">
  <div class="background-overlay"></div>

  <div class="promo-section_container">
    <!-- Texto Principal (Visible en ambos, posición cambia) -->
    <div class="header-content">
      <h3 class="main-title">
        <span class="text-p">Skip the Line.</span>
        <br />
        <strong class="text-main">Get the Best.</strong>
      </h3>
      <p class="text-p subtitle">
        <strong>Reserve priority access to DP-M2 for just $1</strong> and lock in
        the lowest price of the entire campaign before Super Early Bird spots sell
        out.
      </p>
    </div>

    <!-- Tarjeta Blanca -->
    <div class="card">
      <div class="price-tag">
        <p class="text-p">$<span>1</span></p>
      </div>

      <ul class="features-list">
        <li class="feature-item">
          <div class="icon-check">
            <svg
              width="16"
              height="16"
              viewBox="0 0 16 16"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M13.6666 4L5.99992 11.6667L2.33325 8"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>
          <div class="feature-text">
            <h3 class="text-h3">Guaranteed Super Early Bird pricing.</h3>
            <p class="text-p">Secure our best launch offer (up to 40% off).</p>
          </div>
        </li>

        <li class="feature-item">
          <div class="icon-check">
            <svg
              width="16"
              height="16"
              viewBox="0 0 16 16"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M13.6666 4L5.99992 11.6667L2.33325 8"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>
          <div class="feature-text">
            <h3 class="text-h3">Batch #1 Priority Shipping</h3>
            <p class="text-p">
              Fast-track your order. Be the first to receive DP-M2.
            </p>
          </div>
        </li>

        <li class="feature-item">
          <div class="icon-check">
            <svg
              width="16"
              height="16"
              viewBox="0 0 16 16"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M13.6666 4L5.99992 11.6667L2.33325 8"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>
          <div class="feature-text">
            <h3 class="text-h3">Insider Updates</h3>
            <p class="text-p">
              Exclusive behind-the-scenes content and early announcements.
            </p>
          </div>
        </li>
      </ul>

      <hr />
      <!-- COUNTDOWN REGISTER -->
      <div class="countdow-register text-h3">
        <div>
          <p>Only</p>
        </div>
        <p class="number" id="count-number-registe-modal">50</p>

        <div>
          <p>spots left!</p>
        </div>
      </div>

      <!-- BUTTON -->
      <a
        rel="noopener noreferrer"
        class="text-main cta-button"
        id="cta-checkout-modal"
        href="https://buy.stripe.com/cNi6oAdeLcCofJ7bnkbV600"
        target="_blank"
      >
        Reserve My Spot Now
      </a>

      <p class="disclaimer text-p" style="margin-bottom: 0;">
        *Priority spots will be limited.
      </p>
      <p class="disclaimer text-p">
        The Kickstarter campaign will be available for US customers only.
        <a href="/terms-and-conditions" style="color:#007aff"> T&C </a>
      </p>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      fetch("https://dpm2.miaomada.co.jp/api/get-stripe-count.php")
        .then((res) => res.json())
        .then((data) => {
          const textCounterVipModal = document.getElementById("count-number-registe-modal");
          if (textCounterVipModal) {
            const mathCounterVipModal = parseInt("50") - parseInt(data.total);
            textCounterVipModal.textContent = mathCounterVipModal.toString();
          }
        })
        .catch((err) => console.error("Error:", err));

      //
      const btnVipModal = document.getElementById("cta-checkout-modal");

      if (btnVipModal) {
        btnVipModal.addEventListener("click", () => {
          // 📊 GA4 event
          if (typeof gtag === "function") {
            gtag("event", "initiate_checkout", {
              method: "Reserve My Spot Now",
              form_name: "Prccing Offer",
              currency: "USD",
              value: 1,
              content_type: "product",
              debug_mode: true,
              content_name: "link_payment",
            });
          } else {
            console.warn("⚠️ gtag is not defined");
          }

          // ✅ Check if Meta Pixel is loaded
          if (typeof fbq === "function") {
            fbq("track", "InitiateCheckout", {
              method: "Reserve My Spot Now",
              value: 1,
              currency: "USD",
              content_type: "product",
              content_name: "link_payment",
              debug_mode: true,
            });
          } else {
            console.warn(
              "⚠️ fbq is not defined - Is the Meta Pixel installed?",
            );
          }
        });
      }
    });
  </script>

</section>
